{
  "name": "@clawnify/open-whiteboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api -c cyan,green \"vite\" \"tsx watch src/server/dev.ts\"",
    "dev:api": "tsx watch src/server/dev.ts",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite build && NODE_ENV=production tsx src/server/dev.ts",
    "start": "NODE_ENV=production tsx src/server/dev.ts"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-openapi": "^0.18.0",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.6.0",
    "lucide-preact": "^0.575.0",
    "preact": "^10.25.0",
    "tailwindcss": "^4.2.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@types/better-sqlite3": "^7.6.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "react": "npm:@preact/compat@^10.25.0",
      "react-dom": "npm:@preact/compat@^10.25.0"
    }
  }
}
